{
  "rewrites": [
    { "source": "/((?!api/).*)", "destination": "/index.html" }
    { "source": "/((?!api/|\\.well-known/).*)", "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/.well-known/assetlinks.json",
      "headers": [
        { "key": "Content-Type", "value": "application/json" },
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
